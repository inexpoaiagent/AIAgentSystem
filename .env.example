# ── AI OS Business Engine — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── LLM Providers ─────────────────────────────────────────────────────────────
# At least one is required for real AI responses.
# Without keys, the system works with deterministic fallback (good for demo).
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Optional alternatives
ANTHROPIC_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=

# ── Backend Secrets ────────────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production_at_least_64_chars_long_random_string
JWT_REFRESH_SECRET=change_me_refresh_secret_at_least_64_chars_long_random_string
VOICE_PROVIDER_SECRET=change_me_voice_secret

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://ai_os:ai_os_dev@localhost:5432/ai_business_os?schema=public
POSTGRES_DB=ai_business_os
POSTGRES_USER=ai_os
POSTGRES_PASSWORD=ai_os_dev

# ── Services ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333

# ── Frontend ───────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8080
VITE_AI_ENGINE_URL=http://localhost:8000

# ── Optional Social APIs (for Business Doctor real data) ──────────────────────
META_ACCESS_TOKEN=
YOUTUBE_API_KEY=
