generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  OWNER
  MANAGER
  MEMBER
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  INVITED
  SUSPENDED
}

enum AgentTier {
  CEO
  MANAGER
  SPECIALIST
  WORKER
  QA
  SECURITY
  COST
}

enum AgentStatus {
  ACTIVE
  PAUSED
  DISABLED
}

enum TaskStatus {
  QUEUED
  RUNNING
  NEEDS_APPROVAL
  APPROVED
  REJECTED
  COMPLETED
  FAILED
  CANCELLED
}

enum ApprovalMode {
  MANUAL
  AUTONOMOUS
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum WorkflowRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum MemoryType {
  COMPANY
  PROJECT
  CONVERSATION
  AGENT
  USER
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  UNPAID
}

enum SubscriptionPlan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum UsageType {
  TOKENS
  VOICE_MINUTES
  BROWSER_MINUTES
  STORAGE_MB
  IMAGE_GENERATIONS
  AGENT_TASKS
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  APPROVE
  REJECT
  EXECUTE
  PUBLISH
  DEPLOY
}

// ── Industry Packs ────────────────────────────────────────────────────────────

model IndustryPack {
  id               String  @id @default(uuid())
  slug             String  @unique
  name             String
  emoji            String  @default("🏢")
  tagline          String  @db.VarChar(500)
  valueProposition String? @db.Text
  targetCustomers  Json    @default("[]")
  painPoints       Json    @default("[]")
  agents           Json    @default("[]")
  outcomes         Json    @default("[]")
  kpis             Json    @default("[]")
  tier             String  @default("professional")
  price            Int     @default(299)
  color            String  @default("#3b82f6")
  gradientFrom     String  @default("#3b82f6")
  gradientTo       String  @default("#8b5cf6")
  isActive         Boolean @default(true)
  sortOrder        Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies Company[]

  @@index([slug])
  @@map("industry_packs")
}

// ── Business Categories ───────────────────────────────────────────────────────

model BusinessCategory {
  id          String  @id @default(uuid())
  name        String  @unique
  slug        String  @unique
  description String? @db.Text
  icon        String? // emoji
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies Company[]

  @@index([slug])
  @@map("business_categories")
}

// ── Companies ─────────────────────────────────────────────────────────────────

model Company {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  industryPackId String? // FK to IndustryPack (DB-driven)
  industry       String? // legacy slug fallback
  categoryId     String? // FK to BusinessCategory
  domain      String?
  locale      String  @default("en")
  logoUrl     String?
  brandVoice  String? @db.Text
  website     String?
  instagram   String?
  facebook    String?
  youtube     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  industryPack    IndustryPack?     @relation(fields: [industryPackId], references: [id])
  category        BusinessCategory? @relation(fields: [categoryId], references: [id])
  users           User[]
  workspaces      Workspace[]
  agents          Agent[]
  agentTasks      AgentTask[]
  meetings        Meeting[]
  workflows       Workflow[]
  memories        Memory[]
  vectorDocuments VectorDocument[]
  toolConnections ToolConnection[]
  subscriptions   Subscription[]
  usageRecords    UsageRecord[]
  invoices        Invoice[]
  auditLogs       AuditLog[]

  @@index([slug])
  @@index([categoryId])
  @@index([industryPackId])
  @@map("companies")
}

// ── Users ──────────────────────────────────────────────────────────────────────

model User {
  id               String     @id @default(uuid())
  companyId        String
  email            String     @unique
  name             String
  passwordHash     String
  role             UserRole   @default(MEMBER)
  status           UserStatus @default(ACTIVE)
  avatarUrl        String?
  locale           String     @default("en")
  lastLoginAt      DateTime?
  twoFactorEnabled Boolean    @default(false)
  twoFactorSecret  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sessions      UserSession[]
  agentTasks    AgentTask[]
  auditLogs     AuditLog[]     @relation("AuditActor")
  voiceSessions VoiceSession[]

  @@index([companyId])
  @@index([email])
  @@map("users")
}

model UserSession {
  id               String    @id @default(uuid())
  userId           String
  refreshTokenHash String    @db.Text
  userAgent        String?   @db.Text
  ipAddress        String?
  expiresAt        DateTime
  revokedAt        DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_sessions")
}

// ── Workspaces ─────────────────────────────────────────────────────────────────

model Workspace {
  id          String  @id @default(uuid())
  companyId   String
  name        String
  description String? @db.Text
  settings    Json    @default("{}")
  presenceMeta Json   @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("workspaces")
}

// ── Agents ─────────────────────────────────────────────────────────────────────

model Agent {
  id          String      @id @default(uuid())
  companyId   String
  slug        String
  name        String
  tier        AgentTier
  personality String?     @db.Text
  goals       Json        @default("[]")
  tools       Json        @default("[]")
  kpis        Json        @default("[]")
  costProfile String      @default("economy")
  riskLevel   RiskLevel   @default(LOW)
  status      AgentStatus @default(ACTIVE)
  config      Json        @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tasks    AgentTask[]
  meetings MeetingAgent[]

  @@unique([companyId, slug])
  @@index([companyId])
  @@map("agents")
}

// ── Agent Tasks ────────────────────────────────────────────────────────────────

model AgentTask {
  id            String       @id @default(uuid())
  companyId     String
  agentId       String?
  requestedById String
  title         String       @db.VarChar(500)
  objective     String       @db.Text
  agentSlugs    Json         @default("[]")
  approvalMode  ApprovalMode @default(MANUAL)
  status        TaskStatus   @default(QUEUED)
  result        Json?
  errorMessage  String?      @db.Text
  costUsd       Decimal?     @db.Decimal(10, 6)
  tokensUsed    Int?
  traceId       String?
  approvedAt    DateTime?
  approvedById  String?
  completedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  agent       Agent?    @relation(fields: [agentId], references: [id])
  requestedBy User      @relation(fields: [requestedById], references: [id])
  meeting     Meeting?

  @@index([companyId, status])
  @@index([companyId, createdAt])
  @@map("agent_tasks")
}

// ── Meetings ───────────────────────────────────────────────────────────────────

model Meeting {
  id             String  @id @default(uuid())
  companyId      String
  agentTaskId    String? @unique
  objective      String  @db.Text
  consensusScore Int     @default(0)
  summary        String? @db.Text
  decision       String? @db.Text
  transcript     Json    @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  agentTask AgentTask?     @relation(fields: [agentTaskId], references: [id])
  agents    MeetingAgent[]

  @@index([companyId])
  @@map("meetings")
}

model MeetingAgent {
  id         String  @id @default(uuid())
  meetingId  String
  agentId    String
  role       String
  confidence Int     @default(0)
  vote       String?
  rationale  String? @db.Text

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  agent   Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([meetingId, agentId])
  @@map("meeting_agents")
}

// ── Workflows ──────────────────────────────────────────────────────────────────

model Workflow {
  id          String         @id @default(uuid())
  companyId   String
  name        String
  description String?        @db.Text
  status      WorkflowStatus @default(DRAFT)
  trigger     Json           @default("{}")
  nodes       Json           @default("[]")
  edges       Json           @default("[]")
  policies    Json           @default("{}")
  version     Int            @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  runs    WorkflowRun[]

  @@index([companyId, status])
  @@map("workflows")
}

model WorkflowRun {
  id           String            @id @default(uuid())
  workflowId   String
  status       WorkflowRunStatus @default(PENDING)
  nodeStatuses Json              @default("{}")
  retryCount   Int               @default(0)
  output       Json?
  errorMessage String?           @db.Text
  startedAt    DateTime?
  completedAt  DateTime?

  createdAt DateTime @default(now())

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@map("workflow_runs")
}

// ── Memories ───────────────────────────────────────────────────────────────────

model Memory {
  id             String     @id @default(uuid())
  companyId      String
  type           MemoryType
  title          String     @db.VarChar(500)
  content        String     @db.Text
  tags           Json       @default("[]")
  source         String?
  classification String?
  importance     Int        @default(5)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vectorDocuments VectorDocument[]

  @@index([companyId, type])
  @@map("memories")
}

model VectorDocument {
  id         String @id @default(uuid())
  companyId  String
  memoryId   String?
  qdrantId   String
  namespace  String
  sourceHash String
  metadata   Json   @default("{}")

  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  memory  Memory? @relation(fields: [memoryId], references: [id])

  @@index([companyId, namespace])
  @@map("vector_documents")
}

// ── Tool Connections ───────────────────────────────────────────────────────────

model ToolConnection {
  id             String    @id @default(uuid())
  companyId      String
  provider       String
  slug           String
  credentialsEnc String    @db.Text
  scopes         Json      @default("[]")
  isActive       Boolean   @default(true)
  lastSyncAt     DateTime?
  expiresAt      DateTime?
  meta           Json      @default("{}")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, slug])
  @@index([companyId])
  @@map("tool_connections")
}

// ── Subscriptions ──────────────────────────────────────────────────────────────

model Subscription {
  id                   String             @id @default(uuid())
  companyId            String             @unique
  plan                 SubscriptionPlan   @default(STARTER)
  status               SubscriptionStatus @default(TRIALING)
  billingCycle         BillingCycle       @default(MONTHLY)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  trialEndsAt          DateTime?
  currentPeriodStart   DateTime           @default(now())
  currentPeriodEnd     DateTime
  cancelledAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  usageRecords UsageRecord[]
  invoices     Invoice[]

  @@map("subscriptions")
}

model UsageRecord {
  id             String    @id @default(uuid())
  companyId      String
  subscriptionId String
  type           UsageType
  quantity       Decimal   @db.Decimal(14, 4)
  unit           String
  traceId        String?
  recordedAt     DateTime  @default(now())

  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([companyId, type])
  @@index([companyId, recordedAt])
  @@map("usage_records")
}

model Invoice {
  id               String   @id @default(uuid())
  companyId        String
  subscriptionId   String
  stripeInvoiceId  String?  @unique
  amountDue        Decimal  @db.Decimal(10, 2)
  amountPaid       Decimal  @db.Decimal(10, 2) @default(0)
  currency         String   @default("usd")
  status           String   @default("open")
  hostedInvoiceUrl String?
  periodStart      DateTime
  periodEnd        DateTime
  paidAt           DateTime?

  createdAt DateTime @default(now())

  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([companyId])
  @@map("invoices")
}

// ── Voice Sessions ─────────────────────────────────────────────────────────────

model VoiceSession {
  id                String    @id @default(uuid())
  userId            String
  providerToken     String    @db.Text
  provider          String    @default("openai_realtime")
  status            String    @default("active")
  durationSeconds   Int?
  transcriptSnippet String?   @db.Text
  expiresAt         DateTime

  createdAt DateTime @default(now())
  endedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("voice_sessions")
}

// ── Audit Logs ─────────────────────────────────────────────────────────────────

model AuditLog {
  id        String      @id @default(uuid())
  companyId String
  actorId   String?
  action    AuditAction
  target    String?
  targetId  String?
  payload   Json?
  ipAddress String?
  userAgent String?     @db.Text
  traceId   String?
  riskLevel RiskLevel   @default(LOW)
  createdAt DateTime    @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  actor   User?   @relation("AuditActor", fields: [actorId], references: [id])

  @@index([companyId, createdAt])
  @@index([companyId, action])
  @@map("audit_logs")
}
