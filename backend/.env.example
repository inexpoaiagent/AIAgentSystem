# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://ai_os:ai_os_dev@localhost:5432/ai_business_os?schema=public"

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET="change_me_to_a_long_random_string_in_production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change_me_to_another_long_random_string"
JWT_REFRESH_EXPIRES_IN="7d"

# ── App ───────────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"

# ── Redis (optional caching) ──────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── AI Engine ─────────────────────────────────────────────────────────────────
AI_ENGINE_URL="http://localhost:8000"

# ── Voice (WebRTC provider token issuer) ──────────────────────────────────────
VOICE_PROVIDER_SECRET="change_me"

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ── MinIO / S3 ────────────────────────────────────────────────────────────────
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minio"
S3_SECRET_KEY="minio_dev_password"
S3_BUCKET="ai-business-os"
